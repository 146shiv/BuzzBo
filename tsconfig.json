{
    "compilerOptions": {
      "target": "ES2020",
      "module": "CommonJS",
      "rootDir": ".",
      "outDir": "./dist",
      "strict": true,
      "esModuleInterop": true,
      "skipLibCheck": true,
      "forceConsistentCasingInFileNames": true,
      "moduleResolution": "node",
      "paths": {
        "@shared/*": ["./shared/*"]
      }
    },
    "include": ["src/**/*", "shared/**/*"]
  }