# Admin API URL (used by Electron/CLI bot)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase — server-side only (never expose secret key to clients or the bot)
# Dashboard: https://supabase.com/dashboard/project/_/settings/api-keys
# Docs: https://supabase.com/docs/guides/getting-started/api-keys
#
# SUPABASE_URL = Project URL from Connect dialog (https://YOUR_REF.supabase.co — no /rest/v1)
# SUPABASE_SECRET_KEY = Secret API key (sb_secret_...) — backend/admin only, bypasses RLS
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SECRET_KEY=sb_secret_your-secret-key-here

# Auth (admin panel JWT)
JWT_SECRET=change-me-to-a-long-random-string

# Encrypt platform account passwords/tokens at rest
ENCRYPTION_KEY=change-me-to-a-32-char-secret

# Database provider (supabase | postgres in future)
DB_PROVIDER=supabase
