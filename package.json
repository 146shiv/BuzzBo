{
  "name": "buzzbo",
  "version": "1.0.0",
  "description": "Buzzbo — Instagram AI engagement bot (Electron desktop + Admin)",
  "private": true,
  "packageManager": "yarn@1.22.22",
  "workspaces": [
    "core",
    "instagram-bot",
    "electron-app",
    "admin",
    "packages/ui"
  ],
  "author": "Shivendra Yadav",
  "license": "ISC",
  "scripts": {
    "dev": "npm run dev -w @buzzbo/admin",
    "dev:electron": "npm run dev -w @buzzbo/electron-app",
    "start": "npm run build:admin && npm run start -w @buzzbo/admin",
    "build:core": "npm run build -w @buzzbo/core",
    "build:instagram-bot": "npm run build -w @buzzbo/instagram-bot",
    "build:electron": "npm run build -w @buzzbo/electron-app",
    "build:admin": "npm run build -w @buzzbo/admin",
    "build": "npm run build:core && npm run build:instagram-bot && npm run build:electron",
    "dist": "npm run dist -w @buzzbo/electron-app",
    "dist:mac": "npm run dist:mac -w @buzzbo/electron-app",
    "dist:win": "npm run dist:win -w @buzzbo/electron-app",
    "dist:linux": "npm run dist:linux -w @buzzbo/electron-app"
  },
  "devDependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^5.8.3"
  }
}
