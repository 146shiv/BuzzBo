{
  "name": "@buzzbo/electron-app",
  "version": "1.0.0",
  "private": true,
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "dist": "node scripts/materialize-workspace-deps.mjs && npm run build && electron-builder --dir"
  },
  "dependencies": {
    "@buzzbo/core": "1.0.0",
    "@buzzbo/instagram-bot": "1.0.0",
    "@buzzbo/ui": "1.0.0",
    "@base-ui/react": "^1.6.0",
    "@fontsource/jetbrains-mono": "^5.2.5",
    "@fontsource/plus-jakarta-sans": "^5.2.5",
    "class-variance-authority": "^0.7.1",
    "lucide-react": "^1.21.0",
    "playwright": "^1.53.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-resizable-panels": "^2.1.9",
    "clsx": "^2.1.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.8",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.5.2",
    "electron": "^36.4.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.1.0",
    "shadcn": "^4.11.0",
    "tailwindcss": "^4.1.8",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  },
  "build": {
    "electronVersion": "36.4.0",
    "appId": "com.buzzbo.app",
    "productName": "Buzzbo",
    "directories": {
      "output": "../release",
      "buildResources": "../build"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/playwright/**",
      "node_modules/playwright-core/**",
      "node_modules/@playwright/**"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [{ "target": "dmg", "arch": ["x64", "arm64"] }]
    }
  }
}
