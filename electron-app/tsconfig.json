{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "paths": {
      "@/*": ["./renderer/src/*"],
      "@buzzbo/core": ["../core/src/index.ts"],
      "@buzzbo/core/*": ["../core/src/*"],
      "@buzzbo/instagram-bot": ["../instagram-bot/src/index.ts"]
    }
  },
  "include": ["main/**/*", "preload/**/*", "renderer/**/*"]
}
